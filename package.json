{
  "name": "ai37-a2ui-catalog-monorepo",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build && pnpm --filter @ai37/a2ui-demo run build",
    "typecheck": "pnpm -r --filter './packages/**' run typecheck && pnpm --filter @ai37/a2ui-demo run typecheck",
    "test": "vitest run && poetry -C packages/catalog-python run pytest ../../tests/python",
    "test:ts": "vitest run tests/ts tests/react",
    "test:python": "poetry -C packages/catalog-python run pytest ../../tests/python",
    "export:schemas": "tsx packages/catalog-schemas/src/generate-artifacts.ts",
    "lint": "pnpm run typecheck",
    "demo": "pnpm --filter @ai37/a2ui-demo run dev",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^27.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  }
}
