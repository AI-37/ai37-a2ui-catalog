                "anyOf": [
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "path": {
                        "type": "string",
                        "description": "A JSON Pointer path to a value in the data model."
                      }
                    },
                    "required": [
                      "path"
                    ],
                    "additionalProperties": false,
                    "description": "REF:common_types.json#/$defs/DataBinding|A JSON Pointer path to a value in the data model."
                  },
