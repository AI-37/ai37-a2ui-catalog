{
  "name": "@ai37/a2ui-catalog-react",
  "version": "0.4.2",
  "description": "React-рендереры A2UI-каталога AI37 для @a2ui/react.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "a2ui",
    "ai37",
    "react",
    "renderers",
    "catalog"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AI-37/ai37-a2ui-catalog.git",
    "directory": "packages/catalog-react"
  },
  "homepage": "https://github.com/AI-37/ai37-a2ui-catalog#readme",
  "bugs": "https://github.com/AI-37/ai37-a2ui-catalog/issues",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@a2ui/react": "^0.10.1",
    "@a2ui/web_core": "^0.10.1",
    "@ai37/a2ui-catalog-schemas": "^0.4.1",
    "katex": "^0.16.22"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
