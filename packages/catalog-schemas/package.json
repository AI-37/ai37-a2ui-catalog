{
  "name": "@ai37/a2ui-catalog-schemas",
  "version": "0.4.0",
  "description": "Каноничные Zod-схемы и метаданные A2UI-каталога AI37 (+ экспорт JSON Schema).",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "require": "./dist/constants.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "a2ui",
    "ai37",
    "zod",
    "json-schema",
    "catalog"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AI-37/ai37-a2ui-catalog.git",
    "directory": "packages/catalog-schemas"
  },
  "homepage": "https://github.com/AI-37/ai37-a2ui-catalog#readme",
  "bugs": "https://github.com/AI-37/ai37-a2ui-catalog/issues",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@a2ui/web_core": "^0.10.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
